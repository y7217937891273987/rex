# OPENAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# REX System Configuration
REX_LOG_LEVEL=INFO
REX_API_PORT=5000
REX_API_HOST=0.0.0.0
REX_ENV=development

# Security
REX_PERMISSION_REQUIRED=true
REX_ADMIN_USER=admin
REX_SECRET_KEY=your_secret_key_here

# Memory
REX_MEMORY_TYPE=hybrid
REX_MEMORY_MAX_ITEMS=10000
REX_MEMORY_PERSISTENCE=sqlite

# Voice
REX_VOICE_ENABLED=true
REX_VOICE_ENGINE=pyttsx3
REX_VOICE_RATE=150

# Self-Expansion
REX_SELF_MODIFY_ENABLED=true
REX_CODE_REVIEW_REQUIRED=true
REX_MAX_ITERATIONS=10

# Database
REX_DB_TYPE=sqlite
REX_DB_PATH=data/rex.db

# Redis (optional, for distributed caching)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
